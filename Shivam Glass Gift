<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>The Local Shop</title>

<style>
*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family:Arial, sans-serif;
}

body{
  scroll-behavior:smooth;
}

/* HERO */
.hero{
  height:100vh;
  background:url('https://i.ibb.co/bR8R0Bv/IMG-0895.jpg') center/cover no-repeat;
  display:flex;
  align-items:center;
  justify-content:center;
  text-align:center;
  color:white;
}

.hero-content{
  background:rgba(0,0,0,0.5);
  padding:30px;
  border-radius:10px;
}

.hero h1{
  font-size:3rem;
}

.hero p{
  margin:10px 0;
}

.btn{
  background:#ff6600;
  color:white;
  padding:10px 20px;
  border:none;
  border-radius:5px;
  cursor:pointer;
  transition:0.3s;
}

.btn:hover{
  background:#e65c00;
}

/* PRODUCTS */
.products{
  padding:40px 20px;
}

.products h2{
  text-align:center;
  margin-bottom:20px;
}

.carousel{
  display:flex;
  overflow-x:auto;
  gap:20px;
  padding-bottom:10px;
}

.card{
  min-width:250px;
  background:white;
  border-radius:10px;
  box-shadow:0 4px 10px rgba(0,0,0,0.1);
  transition:0.3s;
}

.card:hover{
  transform:translateY(-5px);
}

.card img{
  width:100%;
  height:200px;
  object-fit:cover;
  border-radius:10px 10px 0 0;
}

.card-body{
  padding:15px;
  text-align:center;
}

.card-body h3{
  margin-bottom:10px;
}

/* CART */
.cart{
  padding:20px;
  background:#f9f9f9;
}

.cart ul{
  list-style:none;
}

.cart li{
  padding:5px 0;
}

/* FORM */
.form{
  padding:30px;
}

input, textarea{
  width:100%;
  padding:10px;
  margin:10px 0;
}

/* WHATSAPP */
.whatsapp{
  position:fixed;
  bottom:20px;
  right:20px;
  background:#25D366;
  color:white;
  padding:15px;
  border-radius:50%;
  font-size:20px;
  text-decoration:none;
}

/* MOBILE */
@media(max-width:600px){
  .hero h1{
    font-size:2rem;
  }
}
</style>
</head>

<body>

<!-- HERO -->
<section class="hero">
  <div class="hero-content">
    <h1>The Local Shop</h1>
    <p>Fresh Finds, Best Prices</p>
    <button class="btn" onclick="scrollToProducts()">Shop Now</button>
  </div>
</section>

<!-- PRODUCTS -->
<section class="products" id="products">
  <h2>Our Products</h2>
  <div class="carousel" id="productList"></div>
</section>

<!-- CART -->
<section class="cart">
  <h2>Your Cart</h2>
  <ul id="cartItems"></ul>
</section>

<!-- ORDER FORM -->
<section class="form">
  <h2>Checkout</h2>
  <form id="orderForm">
    <input type="text" placeholder="Your Name" required>
    <input type="tel" placeholder="Phone Number" required>
    <textarea placeholder="Address" required></textarea>
    <textarea id="orderDetails" readonly></textarea>
    <button class="btn" type="submit">Place Order</button>
  </form>
</section>

<!-- WHATSAPP -->
<a href="https://wa.me/9999999999" class="whatsapp">💬</a>

<script>
const products = [
  {name:"Product 1", price:100, img:"https://i.ibb.co/V0LkyPq9/download-6.jpg"},
  {name:"Product 2", price:150, img:"https://i.ibb.co/5NpWGfX/download-4.jpg"},
  {name:"Product 3", price:200, img:"https://i.ibb.co/dJB65JWZ/download-3.jpg"},
  {name:"Product 4", price:120, img:"https://i.ibb.co/3Yhd99Ft/12.jpg"},
  {name:"Product 5", price:180, img:"https://i.ibb.co/5NpWGfX/download-4.jpg"}
];

let cart = [];

function displayProducts(){
  const list = document.getElementById("productList");
  products.forEach((p,i)=>{
    list.innerHTML += `
      <div class="card">
        <img src="${p.img}">
        <div class="card-body">
          <h3>${p.name}</h3>
          <p>₹${p.price}</p>
          <button class="btn" onclick="addToCart(${i})">Add to Cart</button>
        </div>
      </div>
    `;
  });
}

function addToCart(i){
  cart.push(products[i]);
  updateCart();
}

function updateCart(){
  const cartList = document.getElementById("cartItems");
  const orderDetails = document.getElementById("orderDetails");

  cartList.innerHTML = "";
  let text = "";

  cart.forEach(item=>{
    cartList.innerHTML += `<li>${item.name} - ₹${item.price}</li>`;
    text += `${item.name} - ₹${item.price}\n`;
  });

  orderDetails.value = text;
}

document.getElementById("orderForm").addEventListener("submit", function(e){
  e.preventDefault();

  const name = this[0].value;
  const phone = this[1].value;
  const address = this[2].value;
  const items = document.getElementById("orderDetails").value;

  const mail = `mailto:example@gmail.com?subject=New Order&body=
Name: ${name}
Phone: ${phone}
Address: ${address}

Items:
${items}`;

  window.location.href = mail;
});

function scrollToProducts(){
  document.getElementById("products").scrollIntoView();
}

displayProducts();
</script>

</body>
</html>
